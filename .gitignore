# ============================================================
# OCRtoODT — Git Ignore Rules
# ============================================================

# ----------------------------
# Build outputs (CMake / Ninja)
# ----------------------------
build/
build-*/
cmake-build*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json
*.ninja
.ninja_deps
.ninja_log


# ----------------------------
# Object / binary artifacts
# ----------------------------
*.o
*.obj
*.a
*.so
*.so.*
*.dll
*.dylib
*.exe

# ----------------------------
# Qt (Creator, moc/uic/rcc intermediates)
# ----------------------------
*.user
*.user.*
*.pro.user
*.qbs.user
*.autosave
*.qmlc
*.jsc
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h

# ----------------------------
# IDE
# ----------------------------
.idea/
.vscode/
.qtcreator/
*.creator
*.creator.user

# ----------------------------
# OS / editor temporary files
# ----------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ----------------------------
# Logs / runtime cache
# ----------------------------
*.log
cache/
.config/

# ----------------------------
# OCR runtime data (not part of repo)
# ----------------------------
tessdata/

# OCR profile runtime exports
ocr_profiles.json

# ----------------------------
# Local test / installation directories
# ----------------------------
test-install/

# ----------------------------
# Temporary / backup files
# ----------------------------
*_old
*.old
_project_dump/
full_project_dump.sh
project_dump.txt
run_build_appimage.sh
project_dump.txt
translations/
.tools/

# ----------------------------
# AppImage / linuxdeploy artifacts
# ----------------------------
AppDir/
squashfs-root/
*.AppImage
*.appimage
linuxdeploy*.AppImage
